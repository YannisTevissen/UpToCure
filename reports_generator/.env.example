# Copy this to .env and fill in the relevant keys.

# ----- LLM provider (default: OpenAI) ----------------------------------------
# Supported providers: openai | gemini | anthropic | ollama | lmstudio | vllm | custom
LLM_PROVIDER=openai

# Override the base URL of an OpenAI-compatible server (Ollama, vLLM, etc.).
# Examples:
#   Ollama:   http://localhost:11434/v1
#   LM Studio:http://localhost:1234/v1
#   vLLM:     http://localhost:8000/v1
#   Gemini:   https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_BASE_URL=

# Cross-provider API key. Falls back to the provider-specific env var below.
# LLM_API_KEY=

# Models. Defaults are cost-aware as of May 2026:
#   generation:   gpt-5            ($1.25 in / $10 out per 1M tokens)
#   translation:  gpt-5-nano       ($0.05 in / $0.40 out per 1M tokens)
# LLM_MODEL=gpt-5
# LLM_TRANSLATION_MODEL=gpt-5-nano

# Per-request timeout in seconds.
# LLM_TIMEOUT_SECONDS=120

# ----- Provider-specific keys -------------------------------------------------
OPENAI_API_KEY=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=

# ----- Optional: DeepL fallback for translator (--provider deepl) -------------
# DEEPL_API_KEY=
